# ════════════════════════════════════════════════════════════════════════════
# AHP 2.0 ENVIRONMENT TEMPLATE
# ════════════════════════════════════════════════════════════════════════════
# DO NOT COMMIT ACTUAL SECRETS TO GIT!
# Use Railway Variables, AWS Secrets Manager, or environment-specific configs
# ════════════════════════════════════════════════════════════════════════════

# ─── ENVIRONMENT & DEBUG ───
ENVIRONMENT=production                    # production | staging | development
DEBUG=False                               # MUST be False in production
PROJECT_NAME="AHP 2.0 Secure"
VERSION=2.0.0

# ─── DATABASE (PostgreSQL) ───
DB_USER=ahpadmin                          # Database user
DB_PASSWORD=                              # GENERATE: openssl rand -base64 20
DB_NAME=ahp_prod                          # Database name
DB_HOST=db.railway.internal               # Railway internal DNS
DB_PORT=5432                              # PostgreSQL port
DATABASE_URL=                             # AUTO: postgresql+asyncpg://user:pass@host:port/db

# ─── CACHE & QUEUE (Redis) ───
REDIS_URL=redis://redis:6379/0            # Redis connection

# ─── SECURITY (CRITICAL - Generate with scripts below) ───
# Generate RSA 2048-bit keypair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=                          # BEGIN/END PRIVATE KEY block
JWT_PUBLIC_KEY=                           # BEGIN/END PUBLIC KEY block
JWT_AUDIENCE=ahp-enterprise-clients
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Generate 32-byte encryption key:
#   openssl rand -base64 32
ENCRYPTION_KEY=                           # 32-byte base64 encoded key

# Secret key for security operations (min 32 chars):
#   openssl rand -hex 32
SECRET_KEY=                               # Min 32 alphanumeric characters

# ─── CORS (CRITICAL - Must be production domains) ───
ALLOWED_ORIGINS=["https://doctor.yourdomain.com","https://patient.yourdomain.com"]

# ─── CLOUD PROVIDER (GCP or AWS) ───
CLOUD_PROVIDER=gcp                        # gcp | aws

# GCP Configuration (if using GCP)
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-gcs-bucket

# AWS Configuration (if using AWS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket

# ─── AI ENGINES (Multi-Provider Support) ───
# Optional: Choose which AI services to use
GEMINI_API_KEY=                           # Google Gemini API key
GROQ_API_KEY=                             # Groq API key
ANTHROPIC_API_KEY=                        # Claude 3 API key
SARVAM_KEY=                               # Sarvam (local LLM)
INSFORGE_BASE_URL=                        # InsForge API base
INSFORGE_ANON_KEY=                        # InsForge anonymous key

# ─── COMMUNICATIONS ───
TWILIO_ACCOUNT_SID=                       # Twilio account SID
TWILIO_AUTH_TOKEN=                        # Twilio auth token
TWILIO_FROM_NUMBER=+1234567890            # Twilio phone number

# ─── OBSERVABILITY ───
SENTRY_DSN=                               # Sentry error tracking DSN
LOG_LEVEL=INFO                            # DEBUG | INFO | WARNING | ERROR | CRITICAL
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ────────────────────────────────────────────────────────────────────────────
# GENERATION COMMANDS (RUN LOCALLY, NEVER IN PRODUCTION)
# ────────────────────────────────────────────────────────────────────────────
# JWT Key Pair: openssl genrsa -out private.pem 2048
# Encryption Key: openssl rand -base64 32
# Secret Key: openssl rand -hex 32
# DB Password: openssl rand -base64 20
#
# Then paste values into Railway Variables tab ONLY (mark as Sensitive)
# ────────────────────────────────────────────────────────────────────────────

