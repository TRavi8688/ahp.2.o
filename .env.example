# --- DATABASE ---
DB_USER=hospynadmin
DB_PASSWORD=            # GENERATE STRONG PASSWORD
DB_NAME=hospyn_prod
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# --- REDIS ---
REDIS_URL=redis://redis:6379/0

# --- SECURITY (CRITICAL) ---
# Generate these using: openssl rand -hex 32
ACCESS_TOKEN_SECRET=    # REQUIRED: min 32 chars
REFRESH_TOKEN_SECRET=   # REQUIRED: min 32 chars and UNIQUE
ENCRYPTION_KEY=        # REQUIRED: 32 bytes (base64) - FOR AES-GCM

# --- CORS ---
ALLOWED_ORIGINS=["https://hospyn.ai", "http://localhost:3000"]

# --- APP SETTINGS ---
ENVIRONMENT=production
DEBUG=False
PROJECT_NAME="Hospyn 2.0 Secure"
