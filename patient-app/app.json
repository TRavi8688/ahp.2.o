{
  "expo": {
    "name": "Hospyn",
    "slug": "hospyn-patient",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8F4F8"
    },
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hospyn.patient",
      "infoPlist": {
        "NSCameraUsageDescription": "Hospyn requires camera access to scan medical reports and profiles.",
        "NSFaceIDUsageDescription": "Hospyn uses FaceID to securely protect your medical data."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E8F4F8"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_FINGERPRINT"
      ],
      "package": "com.hospyn.patient"
    },
    "privacyPolicyUrl": "https://hospyn.com/privacy",
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-updates",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Hospyn to use the camera to scan medical reports and profiles."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.22",
            "crunchPngs": false
          }
        }
      ],
      "@sentry/react-native"
    ],
    "web": {
      "bundler": "webpack"
    },
    "extra": {
      "eas": {
        "projectId": "3ef75e8f-a9b3-406c-95cc-785da240e295"
      }
    },
    "owner": "hospyn"
  }
}
